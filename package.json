{
  "name": "@taifoon/sonar-sdk",
  "version": "0.1.0",
  "description": "Taifoon ↔ Sonar.trade Integration SDK",
  "type": "module",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start:proof-anchor": "node --loader ts-node/esm src/proof-anchor/api.ts",
    "start:signal-relay": "node --loader ts-node/esm src/signal-relay/relay-service.ts",
    "dev": "tsx watch src/proof-anchor/api.ts",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "taifoon",
    "sonar",
    "defi",
    "blockchain",
    "proofs",
    "mmr",
    "cross-chain"
  ],
  "author": "Taifoon Network",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taifoon/taifoon-sonar.git"
  },
  "dependencies": {
    "ethers": "^6.10.0",
    "eventsource": "^2.0.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
