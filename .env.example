# Taifoon ↔ Sonar Integration — Environment Variables

# ── Proof Anchoring (Taifoon → Sonar) ────────────────────────────────────────
TAIFOON_API_URL=https://api.taifoon.dev
TAIFOON_API_KEY=your_api_key_here
OPERATOR_KEY=your_operator_private_key_here

# ── Signal Relay (Taifoon → Sonar) ───────────────────────────────────────────
TAIFOON_SSE_URL=https://scanner.taifoon.dev/signals-api
SONAR_WEBHOOK_URL=https://sonar.trade/api/integrations/taifoon/signals
SONAR_WEBHOOK_SECRET=your_webhook_secret_here

# ── Sonar API Key (for Sonar → Taifoon) ──────────────────────────────────────
SONAR_API_KEY=sonar_production_key_here

# ── Server Configuration ──────────────────────────────────────────────────────
PORT=8082
NODE_ENV=development

# ── Optional: Database ────────────────────────────────────────────────────────
# POSTGRES_URL=postgresql://user:pass@localhost:5432/taifoon_sonar
# ROCKSDB_PATH=./data/proofs
